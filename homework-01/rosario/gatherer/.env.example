# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).

# --- Required secrets ---
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# --- Postgres (used by both the db service and the backend's DATABASE_URL) ---
POSTGRES_USER=gatherer
POSTGRES_PASSWORD=gatherer
POSTGRES_DB=gatherer

# --- Claude models (ids only; the SDK reads ANTHROPIC_API_KEY) ---
DIGEST_MODEL=claude-sonnet-4-6
CLUSTER_MODEL=claude-haiku-4-5

# --- Scheduler ---
# Cron for per-topic runs (UTC). Default: daily at 06:00.
DEFAULT_SCHEDULE_CRON=0 6 * * *
SCHEDULER_ENABLED=true

# --- Agent (ReAct) loop — cost controls (optional; defaults shown) ---
# Max reasoning turns per finding before the digest is force-written.
AGENT_MAX_ITERATIONS=6
# Per-turn output ceiling (thinking + text share this).
AGENT_MAX_TOKENS=12000
# HARD per-finding token budget (input+output+cache). Once exceeded, the next
# turn is forced to write the digest and stop — this is the cost cap.
AGENT_TOKEN_BUDGET=60000

# --- Logging ---
LOG_LEVEL=INFO
